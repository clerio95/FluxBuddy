# FluxBuddy Configuration
# Copy this file to .env and fill in your values.

# ── Telegram ─────────────────────────────────────────────
TG_BOT_TOKEN=your_bot_token_here

# Group chat ID for automated messages (optional)
GROUP_CHAT_ID=

# ── Authorization ────────────────────────────────────────
# Comma-separated Telegram user IDs
ADMIN_USER_IDS=
OPERATOR_USER_IDS=
ALLOWED_USER_IDS=

# Default role for unlisted users: "none" (deny) or "viewer" (allow)
DEFAULT_ROLE=none

# ── Logging ──────────────────────────────────────────────
LOG_FILE=logs/fluxbuddy.log
LOG_MAX_BYTES=52428800

# ── Timezone ─────────────────────────────────────────────
APP_TIMEZONE=America/Sao_Paulo

# ── Module: occurrences (example) ────────────────────────
# OCCURRENCES_FILE_PATH=path/to/occurrences.txt
# OCCURRENCES_POLL_INTERVAL=120

# ── Module: deadlines (example) ──────────────────────────
# DEADLINES_FILE_PATH=path/to/deadlines.csv
# DEADLINES_DATE_COLUMN=DATE
# DEADLINES_DESCRIPTION_COLUMN=DESCRIPTION
# DEADLINES_CSV_SEPARATOR=;
# DEADLINES_CSV_ENCODING=utf-8-sig
# DEADLINES_ALERT_DAYS=30
# DEADLINES_ALERT_TIME=09:10
